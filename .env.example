# Copy this file to `.env.local` for development, or `.env` for production.
# `.env.local` and `.env` are git-ignored.
# In Development the API auto-loads `.env.local` via DotNetEnv.
# In Production the Docker-Compose stack loads `.env` via --env-file.
# =============================================================================

# ── Deployment (production only) ────────────────────────────────────────────
# Public hostname Caddy will get a Let's Encrypt cert for. Must resolve to the
# EC2 Elastic IP before you bring the stack up, or ACME will fail.
DOMAIN_NAME=sentinelops.example.com
# Email Let's Encrypt uses to send cert-expiry warnings. Required for auto-TLS.
ACME_EMAIL=you@example.com

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=socplatform
POSTGRES_USER=socadmin
POSTGRES_PASSWORD=SocDev2026

# ── Redis (cache + SignalR backplane + rate-limit counters) ─────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=SocRedisDev2026

# ── RabbitMQ (log ingestion queue) ──────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=socadmin
RABBITMQ_PASSWORD=SocRabbitDev2026

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-USE-AT-LEAST-256-BIT-KEY-HERE-SOC-2026
JWT_ISSUER=SOCPlatform
JWT_AUDIENCE=SOCPlatform.Web
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# ── Email (SendGrid in prod / MailHog SMTP in dev) ──────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-key-here
EMAIL_FROM_ADDRESS=noreply.sentinelops@wallystudio.in
EMAIL_FROM_NAME=SentinelOps SOC
EMAIL_REPLY_TO=abhijeetrane204@gmail.com
SMTP_HOST=localhost
SMTP_PORT=1025

# ── Threat Intelligence Providers ───────────────────────────────────────────
ABUSEIPDB_API_KEY=your-abuseipdb-key-here
VIRUSTOTAL_API_KEY=your-virustotal-key-here

# ── ML Microservice ─────────────────────────────────────────────────────────
# Dev default points at local uvicorn; in prod the compose network DNS
# resolves `ml` to the container, so override to http://ml:8001 there.
ML_SERVICE_URL=http://localhost:8001

# ── CORS (comma-separated) ──────────────────────────────────────────────────
# Dev: Vite dev server origins. Prod: set to https://${DOMAIN_NAME}.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
