# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored.
# In Development the API auto-loads `.env.local` via DotNetEnv.
# In Production, inject these via AWS Secrets Manager / Docker secrets.
# =============================================================================

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=socplatform
POSTGRES_USER=socadmin
POSTGRES_PASSWORD=SocDev2026

# ── Redis (cache + SignalR backplane + rate-limit counters) ─────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=SocRedisDev2026

# ── RabbitMQ (log ingestion queue) ──────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=socadmin
RABBITMQ_PASSWORD=SocRabbitDev2026

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-USE-AT-LEAST-256-BIT-KEY-HERE-SOC-2026
JWT_ISSUER=SOCPlatform
JWT_AUDIENCE=SOCPlatform.Web
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# ── Email (SendGrid in prod / MailHog SMTP in dev) ──────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-key-here
EMAIL_FROM_ADDRESS=noreply.sentinelops@wallystudio.in
EMAIL_FROM_NAME=SentinelOps SOC
EMAIL_REPLY_TO=abhijeetrane204@gmail.com
SMTP_HOST=localhost
SMTP_PORT=1025

# ── Threat Intelligence Providers ───────────────────────────────────────────
ABUSEIPDB_API_KEY=your-abuseipdb-key-here
VIRUSTOTAL_API_KEY=your-virustotal-key-here

# ── ML Microservice ─────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8001

# ── CORS (comma-separated) ──────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
