<Window x:Class="SOCPlatform.DesktopAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SOC Platform Agent" Height="340" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E2E" CornerRadius="4" Padding="20">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="🛡️ SOC Platform Agent" FontSize="18" FontWeight="Bold"
                       Foreground="#89B4FA" Margin="0,0,0,16"/>

            <!-- Status Grid -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Status:" Style="{StaticResource LabelStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="StatusText" Text="Initializing..."
                           Style="{StaticResource ValueStyle}" Foreground="#A6E3A1"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Connection:" Style="{StaticResource LabelStyle}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ConnectionText" Text="Checking..."
                           Style="{StaticResource ValueStyle}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Logs Collected:" Style="{StaticResource LabelStyle}"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LogsCollectedText" Text="0"
                           Style="{StaticResource ValueStyle}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Logs Sent:" Style="{StaticResource LabelStyle}"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LogsSentText" Text="0"
                           Style="{StaticResource ValueStyle}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Buffered (offline):" Style="{StaticResource LabelStyle}"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="BufferedText" Text="0"
                           Style="{StaticResource ValueStyle}"/>
            </Grid>

            <!-- Last Activity -->
            <Border Background="#2A2A3E" CornerRadius="4" Padding="10" Margin="0,4,0,12">
                <StackPanel>
                    <TextBlock Text="Last Activity" FontSize="11" Foreground="#6C7086" Margin="0,0,0,4"/>
                    <TextBlock x:Name="LastActivityText" Text="Waiting for first collection cycle..."
                               FontSize="12" Foreground="#CDD6F4" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ToggleButton" Content="Stop" Width="80" Height="30"
                        Margin="0,0,8,0" Click="ToggleButton_Click"
                        Background="#F38BA8" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"/>
                <Button Content="Hide" Width="80" Height="30"
                        Click="HideButton_Click"
                        Background="#45475A" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
