{
  "_security_note": "This file MUST NOT contain real secrets. Every value below is either harmless metadata, a local-dev placeholder, or empty. In Development, values are filled by appsettings.Development.json (git-ignored) or .env.local. In Production, the Docker Compose stack injects them as env vars (see soc_platform/.env.example). Program.cs hard-fails at startup in Production if any required secret is missing or still a placeholder.",

  "ConnectionStrings": {
    "DefaultConnection": "",
    "Hangfire": ""
  },
  "JwtSettings": {
    "Issuer": "SOCPlatform",
    "Audience": "SOCPlatform.Web",
    "SecretKey": "",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Auth": {
    "PasswordResetTokenLifetimeMinutes": 60,
    "FrontendBaseUrl": "http://localhost:5173"
  },
  "Soar": {
    "ApprovalTimeoutMinutes": 30,
    "AutoRejectAfterMinutes": 0
  },
  "Redis": {
    "Host": "",
    "Port": 6379,
    "Password": "",
    "Database": 0,
    "InstanceName": "socplatform:"
  },
  "RabbitMq": {
    "Host": "",
    "Port": 5672,
    "UserName": "",
    "Password": "",
    "VirtualHost": "/",
    "LogIngestionExchange": "soc.logs",
    "LogIngestionQueue": "soc.logs.ingest"
  },
  "MlService": {
    "BaseUrl": "",
    "ApiKey": "",
    "TimeoutSeconds": 30
  },
  "Email": {
    "Provider": "Smtp",
    "FromAddress": "",
    "FromName": "SentinelOps SOC",
    "ReplyTo": "",
    "Smtp": {
      "Host": "",
      "Port": 1025,
      "UseSsl": false
    },
    "SendGrid": {
      "ApiKey": ""
    }
  },
  "ThreatIntel": {
    "CacheTtlSeconds": 3600,
    "AbuseIpDb": {
      "ApiKey": "",
      "BaseUrl": "https://api.abuseipdb.com/api/v2/",
      "MaxConfidenceAge": 90
    },
    "VirusTotal": {
      "ApiKey": "",
      "BaseUrl": "https://www.virustotal.com/api/v3/"
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimiting": {
    "DashboardRequestsPerMinute": 100,
    "IngestionRequestsPerMinute": 1000
  },
  "LogRetention": {
    "RetentionDays": 14
  },
  "Security": {
    "RequireHmacIngestion": true,
    "MetricsScrapeToken": "",
    "AllowInsecureAgentTls": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Hangfire": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
